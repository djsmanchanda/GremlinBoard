{
  "name": "gremlinboard",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:api": "uvicorn --app-dir apps/api gremlinboard_api.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:web": "npm --workspace apps/web run dev",
    "dev": "npm run dev:web",
    "start:api": "uvicorn --app-dir apps/api gremlinboard_api.main:app --host 0.0.0.0 --port 8000",
    "build": "npm --workspace apps/web run build",
    "build:web": "npm --workspace apps/web run build",
    "lint": "npm --workspace apps/web run lint",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck": "npm --workspace apps/web run typecheck",
    "typecheck:web": "npm --workspace apps/web run typecheck"
  }
}
