NEXT_PUBLIC_GREMLINBOARD_API_URL=http://localhost:8000/api

GREMLINBOARD_ENVIRONMENT=development
GREMLINBOARD_API_HOST=127.0.0.1
GREMLINBOARD_API_PORT=8000
GREMLINBOARD_WEB_ORIGIN=http://localhost:3000
GREMLINBOARD_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3100","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3100"]
GREMLINBOARD_DATABASE_URL=sqlite+aiosqlite:///./data/gremlinboard.db
GREMLINBOARD_DEFAULT_BOARD_ID=main
GREMLINBOARD_DEFAULT_USER_ID=local_operator
GREMLINBOARD_DEFAULT_USER_EMAIL=operator@gremlinboard.local
GREMLINBOARD_DEFAULT_USER_NAME=Local Operator
GREMLINBOARD_SESSION_COOKIE_NAME=gremlinboard_session
GREMLINBOARD_SESSION_TTL_HOURS=168
GREMLINBOARD_SESSION_TOUCH_INTERVAL_SECONDS=300
