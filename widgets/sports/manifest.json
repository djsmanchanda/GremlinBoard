{
  "id": "sports",
  "version": "1.0.0",
  "name": "Sports Pulse",
  "category": "sports",
  "description": "Dense live sports monitor for IPL, F1, football, and other sports feeds.",
  "min_size": "2x2",
  "preferred_size": "4x2",
  "allowed_sizes": ["2x2", "4x2", "4x4"],
  "refresh_policy": {
    "mode": "live",
    "interval_seconds": 120
  },
  "lifecycle_policy": {
    "stateful": true,
    "expires": false,
    "default_ttl_seconds": null
  },
  "runtime_policy": {
    "start_timeout_seconds": 8,
    "refresh_timeout_seconds": 8,
    "heartbeat_timeout_seconds": 240,
    "max_retries": 4,
    "retry_backoff_seconds": 2,
    "stale_after_seconds": 600
  },
  "permissions": ["network"],
  "renderer": {
    "target": "react",
    "module": "@widgets/sports/renderer",
    "export_name": "SportsRenderer"
  },
  "service": {
    "module": "widgets.sports.backend",
    "class_name": "SportsWidgetService"
  },
  "config_schema": "config.schema.json"
}
