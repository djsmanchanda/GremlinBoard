{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "sport": {
      "type": "string",
      "enum": ["ipl", "f1", "football"],
      "default": "ipl"
    },
    "provider": {
      "type": "string",
      "enum": ["auto", "cricketdata", "openf1", "football-data"],
      "default": "auto"
    },
    "competition_code": {
      "type": "string",
      "default": "PL"
    },
    "tournament": {
      "type": "string",
      "default": "IPL"
    },
    "refresh_behavior": {
      "type": "string",
      "enum": ["auto", "live", "interval", "manual"],
      "default": "auto"
    },
    "refresh_interval_seconds": {
      "type": "integer",
      "minimum": 10,
      "maximum": 3600,
      "default": 30
    },
    "cache_ttl_seconds": {
      "type": "integer",
      "minimum": 5,
      "maximum": 3600,
      "default": 20
    }
  },
  "additionalProperties": false
}
