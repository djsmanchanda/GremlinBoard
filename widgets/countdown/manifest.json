{
  "id": "countdown",
  "name": "Countdown Timer",
  "category": "utility",
  "description": "Persistent countdown widget for release windows, sessions, and deadlines.",
  "min_size": "1x1",
  "preferred_size": "1x2",
  "allowed_sizes": ["1x1", "1x2", "2x2"],
  "refresh_policy": {
    "mode": "live",
    "interval_seconds": 1
  },
  "lifecycle_policy": {
    "stateful": true,
    "expires": true,
    "default_ttl_seconds": null
  },
  "permissions": [],
  "renderer": {
    "target": "countdown"
  },
  "service": {
    "module": "widgets.countdown.backend",
    "class_name": "CountdownWidgetService"
  },
  "config_schema": "config.schema.json"
}
