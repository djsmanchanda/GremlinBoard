{
  "id": "news",
  "version": "1.0.0",
  "name": "News Radar",
  "category": "news",
  "description": "Refreshes curated news headlines every 10 minutes.",
  "min_size": "1x2",
  "preferred_size": "2x2",
  "allowed_sizes": ["1x2", "2x2", "4x2"],
  "refresh_policy": {
    "mode": "interval",
    "interval_seconds": 600
  },
  "lifecycle_policy": {
    "stateful": true,
    "expires": false,
    "default_ttl_seconds": null
  },
  "runtime_policy": {
    "start_timeout_seconds": 8,
    "refresh_timeout_seconds": 8,
    "heartbeat_timeout_seconds": 900,
    "max_retries": 3,
    "retry_backoff_seconds": 2,
    "stale_after_seconds": 1800
  },
  "permissions": ["network"],
  "renderer": {
    "target": "react",
    "module": "@widgets/news/renderer",
    "export_name": "NewsRenderer"
  },
  "service": {
    "module": "widgets.news.backend",
    "class_name": "NewsWidgetService"
  },
  "config_schema": "config.schema.json"
}
