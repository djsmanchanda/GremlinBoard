{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "provider": {
      "type": "string",
      "enum": ["auto", "rss", "newsapi"],
      "default": "rss"
    },
    "topic": {
      "type": "string",
      "default": "openclaw"
    },
    "feed_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "https://news.ycombinator.com/rss",
        "https://www.theverge.com/rss/index.xml"
      ]
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 5
    },
    "language": {
      "type": "string",
      "default": "en"
    },
    "refresh_behavior": {
      "type": "string",
      "enum": ["auto", "interval", "manual"],
      "default": "interval"
    },
    "refresh_interval_seconds": {
      "type": "integer",
      "minimum": 30,
      "maximum": 3600,
      "default": 600
    },
    "cache_ttl_seconds": {
      "type": "integer",
      "minimum": 30,
      "maximum": 3600,
      "default": 300
    }
  },
  "additionalProperties": false
}
