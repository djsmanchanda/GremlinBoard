{
  "id": "trending",
  "version": "1.0.0",
  "name": "Trend Stack",
  "category": "social",
  "description": "Dense trend stack for Reddit, X, Hacker News, and extensible future sources.",
  "min_size": "1x2",
  "preferred_size": "2x4",
  "allowed_sizes": ["1x2", "2x2", "2x4", "4x4"],
  "refresh_policy": {
    "mode": "interval",
    "interval_seconds": 300
  },
  "lifecycle_policy": {
    "stateful": true,
    "expires": false,
    "default_ttl_seconds": null
  },
  "runtime_policy": {
    "start_timeout_seconds": 8,
    "refresh_timeout_seconds": 8,
    "heartbeat_timeout_seconds": 600,
    "max_retries": 3,
    "retry_backoff_seconds": 2,
    "stale_after_seconds": 1200
  },
  "permissions": ["network"],
  "renderer": {
    "target": "react",
    "module": "@widgets/trending/renderer",
    "export_name": "TrendingRenderer"
  },
  "service": {
    "module": "widgets.trending.backend",
    "class_name": "TrendingWidgetService"
  },
  "config_schema": "config.schema.json"
}
