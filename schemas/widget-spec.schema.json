{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gremlinboard.local/schemas/widget-spec.schema.json",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "description",
    "min_size",
    "preferred_size",
    "refresh_policy",
    "source_type",
    "permissions",
    "output_schema",
    "renderer_type",
    "lifecycle_policy"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "min_size": {
      "enum": ["1x1", "1x2", "2x2", "4x2", "2x4", "4x4"]
    },
    "preferred_size": {
      "enum": ["1x1", "1x2", "2x2", "4x2", "2x4", "4x4"]
    },
    "refresh_policy": {
      "type": "object",
      "required": ["mode", "interval_seconds"],
      "properties": {
        "mode": {
          "enum": ["manual", "interval", "live"]
        },
        "interval_seconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "source_type": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_schema": {
      "type": "object"
    },
    "renderer_type": {
      "type": "string"
    },
    "lifecycle_policy": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
