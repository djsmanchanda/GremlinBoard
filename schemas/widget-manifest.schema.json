{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gremlinboard.local/schemas/widget-manifest.schema.json",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "description",
    "min_size",
    "preferred_size",
    "allowed_sizes",
    "refresh_policy",
    "lifecycle_policy",
    "permissions",
    "renderer",
    "service",
    "config_schema"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "min_size": {
      "$ref": "#/$defs/tileSize"
    },
    "preferred_size": {
      "$ref": "#/$defs/tileSize"
    },
    "allowed_sizes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tileSize"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "refresh_policy": {
      "type": "object",
      "required": ["mode", "interval_seconds"],
      "properties": {
        "mode": {
          "enum": ["manual", "interval", "live"]
        },
        "interval_seconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "lifecycle_policy": {
      "type": "object",
      "required": ["stateful", "expires"],
      "properties": {
        "stateful": {
          "type": "boolean"
        },
        "expires": {
          "type": "boolean"
        },
        "default_ttl_seconds": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "renderer": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "required": ["module", "class_name"],
      "properties": {
        "module": {
          "type": "string"
        },
        "class_name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "config_schema": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "tileSize": {
      "type": "string",
      "enum": ["1x1", "1x2", "2x2", "4x2", "2x4", "4x4"]
    }
  }
}
